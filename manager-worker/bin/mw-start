#!/bin/bash
# Start codex_wp in worker

set -euo pipefail

WORKER_ID=${1:-5}

wezterm cli send-text --pane-id "$WORKER_ID" --no-paste "codex_wp"
sleep 0.3
wezterm cli send-text --pane-id "$WORKER_ID" --no-paste $'\x0d'

echo "🚀 Started codex_wp in worker $WORKER_ID"
echo "Next: confirm startup snapshot, then if trust prompt appears run mw-trust $WORKER_ID"
