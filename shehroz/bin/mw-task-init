#!/bin/bash
# Create a task-first run root with a contract template.
# Usage:
#   mw-task-init --project-root /abs/project --workdir /abs/workdir \
#     [--board-slug <trello-project-slug>] [--card-id 0011] [--lane 03-in-progress] \
#     [--run-root /custom/path] [--task-id task-001] \
#     [--done-template implementation|review|docs|investigation] [--reference /abs/path ...]
#
# Default run-root location:
#   With card:   $MANAGER_MEMORY_ROOT/TRELLO/projects/<slug>/<lane>/<card-id>-<card-slug>/tasks/<run-id>/
#   Without card: $MANAGER_MEMORY_ROOT/TRELLO/projects/<slug>/00-info/active-tasks/<run-id>/
# Override with --run-root for backward compatibility.

set -euo pipefail

MANAGER_MEMORY_ROOT="/Users/al/TOOLS/manager_wezterm_cli/.MEMORY"

PROJECT_ROOT=""
WORKDIR=""
RUN_ROOT=""
TASK_ID=""
DONE_TEMPLATE="implementation"
REFERENCES=()
BOARD_SLUG=""
CARD_ID=""
LANE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --project-root)
            PROJECT_ROOT="${2:-}"
            shift 2
            ;;
        --workdir)
            WORKDIR="${2:-}"
            shift 2
            ;;
        --run-root)
            RUN_ROOT="${2:-}"
            shift 2
            ;;
        --task-id)
            TASK_ID="${2:-}"
            shift 2
            ;;
        --done-template)
            DONE_TEMPLATE="${2:-}"
            shift 2
            ;;
        --reference)
            REFERENCES+=("${2:-}")
            shift 2
            ;;
        --board-slug)
            BOARD_SLUG="${2:-}"
            shift 2
            ;;
        --card-id)
            CARD_ID="${2:-}"
            shift 2
            ;;
        --lane)
            LANE="${2:-}"
            shift 2
            ;;
        *)
            echo "Unknown argument: $1" >&2
            exit 1
            ;;
    esac
done

if [[ -z "$PROJECT_ROOT" || -z "$WORKDIR" ]]; then
    echo "Usage: mw-task-init --project-root /abs/project --workdir /abs/workdir [--board-slug <slug>] [--card-id 0011] [--lane 03-in-progress] [--run-root /custom/path] [--task-id task-001] [--done-template implementation|review|docs|investigation] [--reference /abs/path ...]" >&2
    exit 1
fi

if [[ -z "$RUN_ROOT" ]]; then
    stamp="$(date -u +%Y%m%d-%H%M%S)"
    if [[ -z "$BOARD_SLUG" ]]; then
        BOARD_SLUG="$(basename "$PROJECT_ROOT" | tr ' ' '-' | tr -cd '[:alnum:]._-' )"
    fi
    if [[ -n "$CARD_ID" && -n "$LANE" ]]; then
        # Find the card folder matching the card-id in the lane
        card_dir=""
        board_path="$MANAGER_MEMORY_ROOT/TRELLO/projects/$BOARD_SLUG/$LANE"
        if [[ -d "$board_path" ]]; then
            card_dir="$(find "$board_path" -maxdepth 1 -type d -name "${CARD_ID}-*" | head -1)"
        fi
        if [[ -n "$card_dir" ]]; then
            RUN_ROOT="$card_dir/tasks/shehroz-$stamp"
        else
            # Card folder not found — use the card-id to build the path anyway
            RUN_ROOT="$board_path/${CARD_ID}-unknown/tasks/shehroz-$stamp"
        fi
    else
        # No card specified — use active-tasks holding area
        RUN_ROOT="$MANAGER_MEMORY_ROOT/TRELLO/projects/$BOARD_SLUG/00-info/active-tasks/shehroz-$stamp"
    fi
fi

if [[ -z "$TASK_ID" ]]; then
    TASK_ID="$(basename "$RUN_ROOT")"
fi

mkdir -p "$RUN_ROOT/prompts" "$RUN_ROOT/results" "$RUN_ROOT/hooks"

task_file="$RUN_ROOT/prompts/task.txt"
metadata_file="$RUN_ROOT/metadata.json"

done_block() {
    case "$DONE_TEMPLATE" in
        implementation)
            cat <<EOF
DONE:
  - target files are updated
  - the relevant lint/type/test command passes
  - no unrelated files were modified
  - \`git diff --stat\` matches the intended scope
EOF
            ;;
        review)
            cat <<EOF
DONE:
  - findings are written with file references
  - severity or risk is explicit
  - no code changes were made unless requested
  - assumptions and open questions are listed separately
EOF
            ;;
        docs)
            cat <<EOF
DONE:
  - the target docs or skill files are updated
  - terminology is consistent with governing instructions
  - the new rule or workflow is placed in the canonical section
  - duplicated or conflicting guidance is removed or called out
EOF
            ;;
        investigation)
            cat <<EOF
DONE:
  - the reproduce or probe steps are listed exactly
  - observed result is captured
  - conclusion states reproduced | not reproduced | inconclusive
  - artifacts or logs are saved when relevant
EOF
            ;;
        *)
            echo "Unknown done template: $DONE_TEMPLATE" >&2
            exit 1
            ;;
    esac
}

{
    echo "WORKDIR: $WORKDIR"
    echo "CONTEXT: project $PROJECT_ROOT plus the current local truth for this task."
    echo "PROBLEM: replace this with the concrete blocker, gap, or requested outcome."
    echo "TASK: replace this with one specific action only."
    done_block
    echo "REFERENCES:"
    echo "  - $PROJECT_ROOT"
    for ref in "${REFERENCES[@]}"; do
        echo "  - $ref"
    done
    cat <<'EOF'

STOP after completing this task. Do NOT continue to other work.
EOF
} > "$task_file"

python3 - "$metadata_file" "$TASK_ID" "$PROJECT_ROOT" "$WORKDIR" "$RUN_ROOT" "$DONE_TEMPLATE" <<'PY'
import json
import sys
from datetime import datetime, timezone

path, task_id, project_root, workdir, run_root, done_template = sys.argv[1:]
payload = {
    "created_at_utc": datetime.now(timezone.utc).isoformat(),
    "task_id": task_id,
    "project_root": project_root,
    "workdir": workdir,
    "run_root": run_root,
    "done_template": done_template,
    "task_file": f"{run_root}/prompts/task.txt",
}
with open(path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, ensure_ascii=False, indent=2)
    handle.write("\n")
PY

echo "RUN_ROOT=$RUN_ROOT"
echo "TASK_ID=$TASK_ID"
echo "TASK_FILE=$task_file"
echo "METADATA=$metadata_file"
echo "Edit the task file before submission, then run:"
echo "  mw-check-contract \"$task_file\""
